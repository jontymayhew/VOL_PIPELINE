  <Trade id="BAR_Up_120_1Y">
    <TradeType>ScriptedTrade</TradeType>
    <Envelope>
      <CounterParty>CPTY</CounterParty>
      <NettingSetId>CPTY</NettingSetId>
    </Envelope>
    <ScriptedTradeData>
      <Script>
        <Code>&lt;![CDATA[
NUMBER Alive, Payoff;
Alive = 1;
FOR d IN (ObservationDates) DO
  IF UpDown * Underlying(d) &gt;= UpDown * Barrier THEN
    Alive = 1 - KnockedOut;
  END;
